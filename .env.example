# ── NEXUS ENVIRONMENT VARIABLES ──
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Supabase (get from supabase.com → your project → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenRouter (get from openrouter.ai → Keys)
# Free models available — no credit card needed
VITE_OPENROUTER_KEY=sk-or-v1-your-key-here

# Gemini (get from aistudio.google.com → Get API Key)
VITE_GEMINI_KEY=your-gemini-key-here

# News API (get from newsapi.org — free tier available)
VITE_NEWS_API_KEY=your-news-api-key-here

# OpenWeatherMap (get from openweathermap.org — free tier available)
VITE_WEATHER_API_KEY=your-weather-api-key-here

# App config
VITE_APP_VERSION=1.0.0
VITE_WEBCRAFT_URL=https://webcraft-studioo.netlify.app
